// Module for generated protobuf + Connect-Go code. Lives at the repo
// root (alongside /proto/) so it's importable from every app without
// crossing the apps/* module boundary.
//
// Do not hand-edit files under this module — run `cd proto && buf
// generate` instead.
module github.com/hangrix/hangrix/gen/go

go 1.26.1

require (
	connectrpc.com/connect v1.20.0
	google.golang.org/protobuf v1.36.11
)
