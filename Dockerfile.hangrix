FROM node:22-alpine AS web-build

RUN apk add --no-cache g++ make python3

WORKDIR /src

COPY . .

RUN corepack enable \
  && pnpm install --frozen-lockfile \
  && pnpm --filter web generate \
  && node apps/hangrix/scripts/copy-web-dist.mjs

FROM golang:1.26 AS go-build

WORKDIR /src

COPY . .
COPY --from=web-build /src/apps/hangrix/internal/web/dist ./apps/hangrix/internal/web/dist

RUN mkdir -p apps/hangrix-runner/internal/agentbin/payload \
    apps/hangrix/internal/modules/runner/binaries/payload \
    /out \
  && rm -f apps/hangrix/internal/modules/runner/binaries/payload/hangrix-runner \
    apps/hangrix/internal/modules/runner/binaries/payload/hangrix-agent \
    apps/hangrix/internal/modules/runner/binaries/payload/hangrix-runner_* \
    apps/hangrix-runner/internal/agentbin/payload/hangrix-agent \
  && CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -trimpath \
    -o apps/hangrix-runner/internal/agentbin/payload/hangrix-agent \
    ./apps/hangrix-agent/cmd/hangrix-agent \
  && CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -trimpath \
    -o apps/hangrix/internal/modules/runner/binaries/payload/hangrix-runner_linux_amd64 \
    ./apps/hangrix-runner/cmd/hangrix-runner \
  && rm -f apps/hangrix-runner/internal/agentbin/payload/hangrix-agent \
  && CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -trimpath \
    -o /out/hangrix \
    ./apps/hangrix/cmd/hangrix

FROM postgres:17-alpine

RUN apk add --no-cache git openssh-client tzdata

WORKDIR /app

COPY --from=go-build /out/hangrix /usr/local/bin/hangrix
COPY apps/hangrix/conf/config.yaml /app/config.yaml

RUN chmod +x /usr/local/bin/hangrix \
  && mkdir -p /data/repos /data/assets /data/attachments

ENV API_SERVER_ADDR=:8080
ENV API_SERVER_URL=http://host.docker.internal:18081
ENV API_DATABASE_DSN=postgres://hangrix:hangrix@postgres:5432/hangrix?sslmode=disable
ENV API_REDIS_ADDR=redis:6379
ENV API_STORAGE_REPOS_PATH=/data/repos
ENV API_STORAGE_ASSETS_PATH=/data/assets
ENV API_STORAGE_ATTACHMENTS_PATH=/data/attachments

EXPOSE 8080

ENTRYPOINT []
CMD ["hangrix", "--config", "/app/config.yaml"]
